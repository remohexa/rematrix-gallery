#!/bin/ash
ROOT_PART=$(mount | sed -n 's|^/dev/\(.*\) on / .*|\1|p')
PART_NUM=${ROOT_PART#mmcblk0p}
DISK=/dev/mmcblk0
#
echo ", +" | sfdisk --force -N $PART_NUM $DISK
#
cat <<EOF > /etc/local.d/resize2.start
#!/bin/ash
resize2fs /dev/$ROOT_PART
rm /etc/local.d/resize2.start
reboot
EOF
chmod +x /etc/local.d/resize2.start
rm /etc/local.d/resize.start
reboot